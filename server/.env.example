# ───────────────────────────────────────────────────────────
# Havyn API — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit your real .env file.
# ───────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
# e.g. mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/havyn?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/havyn

# JSON Web Token
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# Stripe (test mode) — get keys from https://dashboard.stripe.com/test/apikeys
# Leave the placeholders as-is to use the built-in mock payment gateway.
STRIPE_SECRET_KEY=your_stripe_test_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_test_publishable_key_here

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
